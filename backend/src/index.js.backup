// ==================== 监控接口 ====================

// 13. 对比快照并查封禁
app.post('/api/monitoring/compare', async (req, res) => {
  try {
    const { platform = 'steam', season, gameMode = 'squad-fpp' } = req.body;
    if (!season) return res.status(400).json({ success: false, error: 'Missing season' });

    // 获取该组合的所有快照
    const allSnapshots = snapshots.getSnapshots(platform, season, gameMode);
    if (allSnapshots.length < 2) {
      return res.status(404).json({
        success: false,
        error: `需要至少 2 个快照才能对比，当前 ${allSnapshots.length} 个`
      });
    }

    // 取最近两个间隔 >= 1 小时的快照
    const latest = snapshots.loadSnapshotByFile(allSnapshots[0].file);
    let previous = null;

    for (let i = 1; i < allSnapshots.length; i++) {
      const candidate = snapshots.loadSnapshotByFile(allSnapshots[i].file);
      const latestTime = new Date(latest.timestamp).getTime();
      const candidateTime = new Date(candidate.timestamp).getTime();
      const diffHours = (latestTime - candidateTime) / (1000 * 60 * 60);
      if (diffHours >= 1) {
        previous = candidate;
        break;
      }
    }

    if (!previous) {
      return res.status(404).json({
        success: false,
        error: '未找到间隔 >= 1 小时的快照对'
      });
    }

    // 对比快照
    const comparison = snapshots.compareSnapshots(previous, latest);

    // 对每个掉榜玩家查封禁状态
    const droppedPlayers = await Promise.all(
      comparison.dropped.map(async (player) => {
        let banInfo = { isBanned: false, banType: null, banDate: null };

        if (STEAM_API_KEY) {
          try {
            const playerName = player.name;
            if (playerName && /^[a-zA-Z0-9_]+$/.test(playerName)) {
              try {
                // 通过 Steam vanity URL 解析玩家名获取 Steam ID
                const steamResolveUrl = `https://api.steampowered.com/ISteamUser/ResolveVanityURL/v1/?key=${STEAM_API_KEY}&vanityurl=${encodeURIComponent(playerName)}`;
                const resolveRes = await fetch(steamResolveUrl);
                const resolveData = await resolveRes.json();
                const steamId = resolveData?.response?.steamid;

                if (steamId) {
                  // 查封禁
                  const banUrl = `https://api.steampowered.com/ISteamUser/GetPlayerBans/v1/?key=${STEAM_API_KEY}&steamids=${steamId}`;
                  const banRes = await fetch(banUrl);
                  const banData = await banRes.json();
                  const ban = banData?.players?.[0];

                  if (ban) {
                    banInfo.isBanned = ban.VACBanned || ban.NumberOfGameBans > 0;
                    if (ban.VACBanned) banInfo.banType = 'VAC';
                    else if (ban.NumberOfGameBans > 0) banInfo.banType = 'Game';
                    banInfo.banDate = ban.DaysSinceLastBan > 0
                      ? new Date(Date.now() - ban.DaysSinceLastBan * 86400000).toISOString().split('T')[0]
                      : null;
                  }
                }
              } catch (e) {
                // Steam 查询失败不阻塞
              }
            }
          } catch (e) {
            // 封禁查询失败不阻塞
          }
        }

        return {
          ...player,
          ...banInfo
        };
      })
    );

    // 过滤掉因 RP 不足正常掉榜的玩家
    // 获取新榜最低 RP
    const minRP = latest.players.reduce((min, p) => Math.min(min, p.rankPoints), Infinity);

    const filteredDropped = droppedPlayers.filter(p => {
      if (p.isBanned) return true;
      if (p.previousRP <= minRP) return false;
      return true;
    });

    res.json({
      success: true,
      data: {
        snapshots: {
          from: previous.timestamp,
          to: latest.timestamp
        },
        players: filteredDropped,
        allDropped: droppedPlayers.length,
        normalDropped: droppedPlayers.length - filteredDropped.length,
        risen: comparison.risen,
        rankChanges: comparison.rankChanges
      }
    });
  } catch (err) {
    console.error(`[monitoring/compare] error: ${err.message}`);
    res.status(500).json({ success: false, error: err.message });
  }
});

// 14. 获取快照列表
app.get('/api/snapshots', (req, res) => {
  try {
    const { platform, season, gameMode } = req.query;
    if (!platform || !season || !gameMode) {
      return res.status(400).json({ success: false, error: 'Missing platform, season, or gameMode' });
    }
    const list = snapshots.getSnapshots(platform, season, gameMode);
    res.json({ success: true, data: list });
  } catch (err) {
    res.status(500).json({ success: false, error: err.message });
  }
});

// 15. 获取监控记录（兼容旧接口）
app.get('/api/monitoring/logs/:platform', (req, res) => {
  try {
    const platform = req.params.platform || 'steam';
    const dir = require('path').join(__dirname, '..', 'snapshots');
    const fs = require('fs');
    if (!fs.existsSync(dir)) return res.json({ success: true, data: [] });

    const files = fs.readdirSync(dir)
      .filter(f => f.startsWith(platform) && f.endsWith('.json'))
      .map(f => {
        const data = JSON.parse(fs.readFileSync(require('path').join(dir, f), 'utf-8'));
        return {
          key: data.key || `${data.platform}_${data.season}_${data.gameMode}`,
          file: f,
          timestamp: data.timestamp,
          playerCount: data.players?.length || 0,
        };
      })
      .sort((a, b) => new Date(b.timestamp) - new Date(a.timestamp));

    res.json({ success: true, data: files });
  } catch (err) {
    res.status(500).json({ success: false, error: err.message });
  }
});

// 16. 保存排行榜快照（手动触发，兼容旧接口）
app.post('/api/monitoring/snapshot', async (req, res) => {
  try {
    const { platform = 'steam', season, gameMode = 'squad-fpp', players } = req.body;
    if (!season || !players) return res.status(400).json({ success: false, error: 'Missing season or players' });

    // 将旧格式 players 转换为 included 格式
    const included = players.map(p => ({
      id: p.playerId || p.id,
      attributes: {
        name: p.name,
        stats: { rankPoints: p.rp || p.rankPoints || 0 },
        rankPoints: p.rp || p.rankPoints || 0,
        tier: p.tier || ''
      }
    }));

    const snapshot = snapshots.saveSnapshot(platform, season, gameMode, included);
    res.json({ success: true, data: snapshot });
  } catch (err) {
    res.status(500).json({ success: false, error: err.message });
  }
});

// ==================== 收藏/批量查询接口 ====================

// 使用简单的 JSON 文件存储
const TRACKED_FILE = require('path').join(__dirname, '..', 'tracked.json');

function getTrackedPlayers() {
  const fs = require('fs');
  try {
    if (fs.existsSync(TRACKED_FILE)) {
      return JSON.parse(fs.readFileSync(TRACKED_FILE, 'utf-8'));
    }
  } catch (e) { /* ignore */ }
  return [];
}

function saveTrackedPlayers(players) {
  const fs = require('fs');
  fs.writeFileSync(TRACKED_FILE, JSON.stringify(players, null, 2));
}

// 17. 获取收藏列表
app.get('/api/tracked', (req, res) => {
  try {
    const list = getTrackedPlayers();
    res.json({ success: true, data: list });
  } catch (err) {
    res.status(500).json({ success: false, error: err.message });
  }
});

// 18. 添加收藏
app.post('/api/tracked', (req, res) => {
  try {
    const { name, platform = 'steam', playerId } = req.body;
    if (!name) return res.status(400).json({ success: false, error: 'Missing name' });

    const list = getTrackedPlayers();
    if (list.length >= 50) {
      return res.status(400).json({ success: false, error: '已达到收藏上限（50个）' });
    }

    const exists = list.find(p => p.name === name && p.platform === platform);
    if (exists) return res.json({ success: true, data: exists, message: '已收藏' });

    const entry = { name, platform, playerId, addedAt: Date.now(), lastChecked: null };
    list.push(entry);
    saveTrackedPlayers(list);
    res.json({ success: true, data: entry });
  } catch (err) {
    res.status(500).json({ success: false, error: err.message });
  }
});

// 19. 删除收藏
app.delete('/api/tracked', (req, res) => {
  try {
    const { name, platform = 'steam' } = req.body;
    const list = getTrackedPlayers();
    const newList = list.filter(p => !(p.name === name && p.platform === platform));
    saveTrackedPlayers(newList);
    res.json({ success: true, data: { removed: list.length - newList.length } });
  } catch (err) {
    res.status(500).json({ success: false, error: err.message });
  }
});

// 20. 批量刷新收藏
app.post('/api/tracked/refresh', async (req, res) => {
  try {
    const list = getTrackedPlayers();
    const updated = [];

    for (const p of list) {
      try {
        const playerData = await getPlayerByName(p.name, p.platform);
        const playerId = playerData.data?.[0]?.id;
        p.playerId = playerId;
        p.lastChecked = Date.now();
        updated.push({ name: p.name, status: 'ok', playerId });
      } catch (e) {
        updated.push({ name: p.name, status: 'error', error: e.message });
      }
    }

    saveTrackedPlayers(list);
    res.json({ success: true, data: updated });
  } catch (err) {
    res.status(500).json({ success: false, error: err.message });
  }
});
