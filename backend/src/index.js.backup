// 9. 综合玩家查询（一次返回所有数据）
app.get('/api/player/:name/full', async (req, res) => {
  try {
    const platform = req.query.platform || 'steam';
    const playerData = await getPlayerByName(req.params.name, platform);
    const playerId = playerData.data[0]?.id;
    if (!playerId) return res.status(404).json({ success: false, error: 'Player not found' });

    const currentSeason = await getCurrentSeason(platform);

    const seasonCacheKey = `season:${platform}:${playerId}:${currentSeason}`;
    const seasonData = await pubgFetch(
      `${PUBG_API_BASE}/shards/${platform}/players/${playerId}/seasons/${currentSeason}`,
      seasonCacheKey,
      600
    );

    // 尝试通过 PUBG player ID (account.id) 获取 Steam ID 并查封禁信息
    let steamBan = null;
    let steamUser = null;
    try {
      const steamIdMatch = playerData.data[0]?.relationships?.matches?.data?.[0]?.id;
      // 有些 PUBG 玩家数据的 attributes.name 可能包含 SteamID
      const pubgAccountId = playerData.data[0]?.attributes?.name;
      
      // 尝试用 Steam ID 搜索（17位数字）
      if (/^\d{17}$/.test(pubgAccountId) || /^7656\d{13}$/.test(pubgAccountId)) {
        const [banRes, userRes] = await Promise.all([
          fetch(`https://api.steampowered.com/ISteamUser/GetPlayerBans/v1/?key=${STEAM_API_KEY}&steamids=${pubgAccountId}`),
          fetch(`https://api.steampowered.com/ISteamUser/GetPlayerSummaries/v2/?key=${STEAM_API_KEY}&steamids=${pubgAccountId}`)
        ]);
        const banJson = await banRes.json();
        const userJson = await userRes.json();
        steamBan = banJson.players?.[0] || null;
        steamUser = userJson.response?.players?.[0] || null;
      }
    } catch (e) {
      // Steam 查询失败不阻塞主流程
    }

    res.json({ success: true, data: {
      player: playerData.data[0],
      season: seasonData,
      seasonId: currentSeason,
      matchIds: seasonData?.data?.relationships?.matches?.data?.slice(0, 10).map(m => m.id) || [],
      steamBan,
      steamUser
    }});
  } catch (err) {
    res.status(500).json({ success: false, error: err.message });
  }
});

