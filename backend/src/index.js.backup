const express = require('express');
const cors = require('cors');
require('dotenv').config();
const cache = require('./cache');
const snapshots = require('./snapshots');
const https = require('https');

const app = express();
const PORT = process.env.PORT || 3000;

app.use(cors());
app.use(express.json());

// ==================== PUBG API 配置 ====================
const PUBG_API_BASE = 'https://api.pubg.com';
const PUBG_API_KEY = process.env.PUBG_API_KEY;
const STEAM_API_KEY = process.env.STEAM_API_KEY;

if (!PUBG_API_KEY) {
  console.error('FATAL: PUBG_API_KEY not set in .env');
  process.exit(1);
}

const commonHeaders = {
  'Authorization': `Bearer ${PUBG_API_KEY}`,
  'Accept': 'application/vnd.api+json'
};

// ==================== 通用工具 ====================
async function pubgFetch(url, cacheKey, ttl) {
  if (cacheKey) {
    const cached = cache.get(cacheKey);
    if (cached) return cached;
  }

  const res = await fetch(url, { headers: commonHeaders });

  if (res.status === 429) {
    throw new Error('请求过于频繁，请稍后重试 (PUBG API rate limited)');
  }
  if (res.status === 503) {
    throw new Error('PUBG 官方API暂时不可用，请稍后重试');
  }
  if (!res.ok) {
    throw new Error(`PUBG API error: ${res.status} ${res.statusText}`);
  }

  const data = await res.json();
  if (cacheKey) cache.set(cacheKey, data, ttl);
  return data;
}

async function getPlayerByName(name, platform = 'steam') {
  const cacheKey = `player:${platform}:${name.toLowerCase()}`;
  return pubgFetch(
    `${PUBG_API_BASE}/shards/${platform}/players?filter[playerNames]=${encodeURIComponent(name)}`,
    cacheKey,
    120 // 2 min cache for player lookup
  );
}

async function getCurrentSeason(platform) {
  const cacheKey = `seasons:${platform}`;
  const data = await pubgFetch(
    `${PUBG_API_BASE}/shards/${platform}/seasons`,
    cacheKey,
    3600 // 1 hour cache for seasons list
  );
  return data.data.find(s => s.attributes.isCurrentSeason)?.id;
}

// ==================== API 路由 ====================

// 1. 玩家查询 - 基础信息
app.get('/api/player/:name', async (req, res) => {
  try {
    const platform = req.query.platform || 'steam';
    const data = await getPlayerByName(req.params.name, platform);
    res.json({ success: true, data });
  } catch (err) {
    console.error(`[player] ${req.params.name}: ${err.message}`);
    res.status(500).json({ success: false, error: err.message });
  }
});

// 2. 玩家赛季统计（合并查询+赛季）
app.get('/api/player/:name/season', async (req, res) => {
  try {
    const platform = req.query.platform || 'steam';
    const playerData = await getPlayerByName(req.params.name, platform);
    const playerId = playerData.data[0]?.id;
    if (!playerId) return res.status(404).json({ success: false, error: 'Player not found' });

    const currentSeason = await getCurrentSeason(platform);

    const seasonCacheKey = `season:${platform}:${playerId}:${currentSeason}`;
    const seasonData = await pubgFetch(
      `${PUBG_API_BASE}/shards/${platform}/players/${playerId}/seasons/${currentSeason}`,
      seasonCacheKey,
      600 // 10 min
    );

    res.json({ success: true, data: {
      player: playerData.data[0],
      season: seasonData,
      seasonId: currentSeason
    }});
  } catch (err) {
    console.error(`[season] ${req.params.name}: ${err.message}`);
    res.status(500).json({ success: false, error: err.message });
  }
});

// 3. 赛季列表
app.get('/api/seasons', async (req, res) => {
  try {
    const platform = req.query.platform || 'steam';
    const data = await pubgFetch(
      `${PUBG_API_BASE}/shards/${platform}/seasons`,
      `seasons:${platform}`,
      3600
    );
    res.json({ success: true, data });
  } catch (err) {
    res.status(500).json({ success: false, error: err.message });
  }
});

// 4. 排行榜
app.get('/api/leaderboard/:platform/:season/:gameMode', async (req, res) => {
  try {
    const { platform, season, gameMode } = req.params;
    const data = await pubgFetch(
      `${PUBG_API_BASE}/shards/${platform}/leaderboards/${season}/${gameMode}`,
      `leaderboard:${platform}:${season}:${gameMode}`,
      3600 // 1 hour cache for leaderboard
    );

    // 自动保存快照（异步，不阻塞响应）
    setImmediate(() => {
      try {
        const included = data?.included || [];
        if (included.length > 0) {
          snapshots.saveSnapshot(platform, season, gameMode, included);
        }
      } catch (e) {
        console.error(`[snapshot] auto-save error: ${e.message}`);
      }
    });

    res.json({ success: true, data });
  } catch (err) {
    res.status(500).json({ success: false, error: err.message });
  }
});

// 5. 对局详情
app.get('/api/match/:matchId', async (req, res) => {
  try {
    const platform = req.query.platform || 'steam';
    const data = await pubgFetch(
      `${PUBG_API_BASE}/shards/${platform}/matches/${req.params.matchId}`,
      `match:${platform}:${req.params.matchId}`,
      3600
    );
    res.json({ success: true, data });
  } catch (err) {
    res.status(500).json({ success: false, error: err.message });
  }
});

// 6. 玩家最近对局列表
app.get('/api/player/:name/matches', async (req, res) => {
  try {
    const platform = req.query.platform || 'steam';
    const playerData = await getPlayerByName(req.params.name, platform);
    const playerId = playerData.data[0]?.id;
    if (!playerId) return res.status(404).json({ success: false, error: 'Player not found' });

    // 获取赛季和对局
    const currentSeason = await getCurrentSeason(platform);
    const seasonCacheKey = `season:${platform}:${playerId}:${currentSeason}`;
    const seasonData = await pubgFetch(
      `${PUBG_API_BASE}/shards/${platform}/players/${playerId}/seasons/${currentSeason}`,
      seasonCacheKey,
      600
    );

    // 取最近的 match IDs
    const matchIds = seasonData?.data?.relationships?.matches?.data?.slice(0, 20) || [];

    res.json({ success: true, data: {
      playerId,
      seasonId: currentSeason,
      matchIds: matchIds.map(m => m.id)
    }});
  } catch (err) {
    res.status(500).json({ success: false, error: err.message });
  }
});

