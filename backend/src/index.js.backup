// PUBG API status + Steam online players
app.get('/api/status', async (req, res) => {
  try {
    // PUBG API status
    const pubgStatusRes = await fetch('https://api.pubg.com/status', {
      headers: { 'Accept': 'application/json' }
    });
    const pubgStatusData = await pubgStatusRes.json();

    // Steam PUBG online players (appid 578080)
    const steamRes = await fetch(
      `https://api.steampowered.com/ISteamUserStats/GetNumberOfCurrentPlayers/v1/?appid=578080`
    );
    const steamData = await steamRes.json();

    res.json({
      success: true,
      data: {
        pubgApi: pubgStatusData,
        steamPlayers: steamData.response?.player_count || 0
      }
    });
  } catch (err) {
    res.json({ success: false, data: { pubgApi: null, steamPlayers: 0 } });
  }
});

